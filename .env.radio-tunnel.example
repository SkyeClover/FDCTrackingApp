# Copy to .env.radio-tunnel and `set -a; source .env.radio-tunnel; set +a` before npm run radio-tunnel
# (Node does not load this file automatically — export vars in your shell or systemd.)

# --- HTTP (tunnel front door) ---
FDC_RADIO_TUNNEL_HOST=127.0.0.1
# FDC_RADIO_TUNNEL_HOST=0.0.0.0
FDC_RADIO_TUNNEL_PORT=8789
# 1 = only localhost may call the tunnel (default). 0 = any client can reach bound address (lab only).
FDC_RADIO_HTTP_LOCALHOST_ONLY=1

# --- Framing (tune for slow RF / high latency links) ---
# Bytes per chunk when splitting JSON envelopes (min 256; not larger than max frame).
FDC_RADIO_CHUNK_BYTES=32000
# Max payload bytes per wire frame (both sides must use the same value).
FDC_RADIO_MAX_FRAME_PAYLOAD=65520
# Max reassembled JSON message (request or response body envelope).
FDC_RADIO_MAX_MESSAGE_BYTES=50331648

# --- Serial port (match radio DATA / USB adapter) ---
FDC_RADIO_SERIAL_PATH=/dev/ttyUSB0
FDC_RADIO_BAUD=115200
# FDC_RADIO_BAUD=9600
# FDC_RADIO_BAUD=19200
FDC_RADIO_DATA_BITS=8
# 1 | 1.5 | 2
FDC_RADIO_STOP_BITS=1
# none | even | odd | mark | space
FDC_RADIO_PARITY=none
# Hardware flow (RTS/CTS)
FDC_RADIO_RTSCTS=0
# Software flow (XON/XOFF)
FDC_RADIO_XONXOFF=0
FDC_RADIO_LOCK=1
FDC_RADIO_HUPCL=1
FDC_RADIO_HIGH_WATER_MARK=65536

# --- Local peer ingest (far end of tunnel forwards here) ---
FDC_PEER_TARGET=http://127.0.0.1:8787

# --- Optional LAN mirror (dual-connected station) ---
# FDC_RADIO_UPSTREAM=http://192.168.1.50:8787
FDC_RADIO_UPSTREAM_TIMEOUT_MS=60000
# Mirror same HTTP to upstream when set (1=yes 0=no).
FDC_RADIO_MIRROR_UPSTREAM=1
# 1 = await upstream mirror (slower; debugging). 0 = fire-and-forget (default).
FDC_RADIO_MIRROR_WAIT=0

# --- Passthrough: no serial, talk to upstream only (bench / LAN) ---
# FDC_RADIO_PASSTHROUGH=upstream

# --- Timeouts (ms). 0 = no AbortSignal timeout on local fetch. ---
FDC_RADIO_SERIAL_RESPONSE_TIMEOUT_MS=120000
FDC_RADIO_FETCH_TIMEOUT_MS=120000

# --- Parser safety ---
FDC_RADIO_PARSE_BUFFER_WARN_BYTES=262144

# --- Logging: 0 off, 1 log, 2 log + hex serial I/O ---
FDC_RADIO_DEBUG=0
