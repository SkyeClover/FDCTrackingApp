# /etc/default/fdc-radio-tunnel — env for fdc-radio-tunnel.service (optional).
# Full list: repo .env.radio-tunnel.example and deploy/RADIO-SYNC.md

FDC_RADIO_TUNNEL_HOST=127.0.0.1
FDC_RADIO_TUNNEL_PORT=8789
FDC_RADIO_HTTP_LOCALHOST_ONLY=1

FDC_RADIO_CHUNK_BYTES=32000
FDC_RADIO_MAX_FRAME_PAYLOAD=65520
FDC_RADIO_MAX_MESSAGE_BYTES=50331648

# Required — e.g. /dev/ttyUSB0 (Linux) or COM3 (Windows dev)
FDC_RADIO_SERIAL_PATH=
FDC_RADIO_BAUD=115200
FDC_RADIO_DATA_BITS=8
FDC_RADIO_STOP_BITS=1
FDC_RADIO_PARITY=none
FDC_RADIO_RTSCTS=0
FDC_RADIO_XONXOFF=0

FDC_PEER_TARGET=http://127.0.0.1:8787

# FDC_RADIO_UPSTREAM=http://192.168.1.50:8787
FDC_RADIO_UPSTREAM_TIMEOUT_MS=60000
FDC_RADIO_MIRROR_UPSTREAM=1
FDC_RADIO_MIRROR_WAIT=0

# FDC_RADIO_PASSTHROUGH=upstream

FDC_RADIO_SERIAL_RESPONSE_TIMEOUT_MS=120000
FDC_RADIO_FETCH_TIMEOUT_MS=120000
FDC_RADIO_PARSE_BUFFER_WARN_BYTES=262144

# FDC_RADIO_DEBUG=1
