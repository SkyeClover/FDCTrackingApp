{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "Dev": false
    }
  },
  "rewrites": [
    {
      "source": "/fdc/v1/health",
      "destination": "/api/fdc?route=health"
    },
    {
      "source": "/fdc/v1/push",
      "destination": "/api/fdc?route=push"
    },
    {
      "source": "/fdc/v1/ping",
      "destination": "/api/fdc?route=ping"
    },
    {
      "source": "/fdc/v1/session-ping",
      "destination": "/api/fdc?route=session-ping"
    },
    {
      "source": "/fdc/v1/browser-offline",
      "destination": "/api/fdc?route=browser-offline"
    },
    {
      "source": "/fdc/v1/offline-notify",
      "destination": "/api/fdc?route=offline-notify"
    },
    {
      "source": "/fdc/v1/status",
      "destination": "/api/fdc?route=status"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

